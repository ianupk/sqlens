# Which database driver to use: postgres | sqlite | mysql
DB_TYPE=postgres

# --- Postgres ---
DATABASE_URL=postgresql://readonly_user:secret@localhost:5432/devdb

# --- SQLite (alternative) ---
# DB_TYPE=sqlite
# SQLITE_PATH=./dev.db

# --- MySQL (alternative) ---
# DB_TYPE=mysql
# MYSQL_HOST=localhost
# MYSQL_USER=readonly_user
# MYSQL_PASSWORD=secret
# MYSQL_DB=devdb